# ==========================================
# Variables de Entorno - Northwind Triage MVP
# ==========================================

# Entorno de ejecución (development, testing, production)
ENVIRONMENT=development

# --- Base de Datos (PostgreSQL) ---
DB_HOST=db
DB_PORT=5432
DB_PORT_LOCAL=5432
DB_NAME=debts_manager
DB_USER=admin
# ATENCIÓN: Cambiar esta contraseña en producción
DB_PASSWORD=admin123

# --- Backend ---
BACKEND_PORT=8080

# --- Frontend ---
# URL base para que el frontend (React) consulte la API
VITE_API_URL=http://localhost:8080
